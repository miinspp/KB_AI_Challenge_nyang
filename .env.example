# 서울 열린데이터광장 Open API 인증키 (https://data.seoul.go.kr → 인증키 신청, 즉시·무료 발급)
# 사용처: pipeline/collect_seoul_sales.py
SEOUL_OPENAPI_KEY=

# (선택) 백엔드가 외부 데이터 파일을 읽게 하려면 경로 지정. 미설정 시 클래스패스 내장 JSON 사용.
# Spring Boot 는 APP_DATA_FILE 환경변수를 application.yml 의 app.data-file 로 자동 바인딩(relaxed binding).
# APP_DATA_FILE=/opt/nyang/backend/src/main/resources/data/industry_distributions.json
